# Copy this file to ".env" next to backend/pom.xml (i.e. E:\BookStore16\backend\.env). Do not commit .env.
# Spring loads it via spring.config.import from ./backend/.env or ./.env (see application.properties).

SPRING_PROFILES_ACTIVE=dev

SERVER_PORT=8080
ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRATION_MS=3600000

DEMO_PAYMENT_DELAY_MS=1200

# --- MySQL (required) ---
# Create the database in MySQL first, e.g.: CREATE DATABASE bookstore_db;
MYSQL_URL=jdbc:mysql://localhost:3306/bookstore_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
MYSQL_USER=root

# REQUIRED on typical Windows/MySQL installs: root has a password. If you leave this empty and MySQL expects
# a password, you get: Access denied for user 'root'@'localhost' (using password: NO)
MYSQL_PASSWORD=put_your_mysql_password_here

# Alternative: use Spring's names instead of MYSQL_PASSWORD (either works in application-*.properties)
# SPRING_DATASOURCE_PASSWORD=put_your_mysql_password_here

# Optional
# DB_POOL_SIZE=10
# JPA_DDL_AUTO=update
# JPA_SHOW_SQL=true
